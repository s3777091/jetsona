# --- Server ---
PORT=9100
# Production: NODE_ENV=production is set by the start script / systemd unit.

# --- Upstreams (where this server proxies to) ---
# WHEP endpoint of the RTSP->WebRTC bridge on the Jetson (reached via the tunnel).
# Example: http://127.0.0.1:8889/jetsona/whep
WHEP_UPSTREAM=

# Raw WebSocket input bridge (jetsona_webrtc_input.py on the Jetson).
# Example: ws://127.0.0.1:46001
INPUT_UPSTREAM=

# Wake-on-LAN HTTP endpoint (jetsona_wol.py on the Jetson), reached via the
# same reverse SSH tunnel as INPUT_UPSTREAM. The Jetson emits the magic packet
# on the PC's LAN. WOL_TOKEN must match JETSON_WOL_TOKEN in /etc/jetsona-wol.env
# on the Jetson.
# Example: http://127.0.0.1:46002
WOL_UPSTREAM=
WOL_TOKEN=

# --- Auth ---
# Token the browser sends as ?token= when upgrading /input. If unset, the page
# renders the literal __JETSONA_INPUT_TOKEN__ placeholder (so an external proxy
# can still substitute it) and the WS upgrade skips token checks.
JETSONA_INPUT_TOKEN=

# Optional HTTP Basic auth protecting the whole site (page + WHEP + WS upgrade).
# Leave both blank to disable.
BASIC_USER=
BASIC_PASS=