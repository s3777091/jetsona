diff --git a/src/libs/tiny_ttf/lv_tiny_ttf.c b/src/libs/tiny_ttf/lv_tiny_ttf.c
index 8994327..9a29a70 100644
--- a/src/libs/tiny_ttf/lv_tiny_ttf.c
+++ b/src/libs/tiny_ttf/lv_tiny_ttf.c
@@ -226,7 +226,18 @@ static bool ttf_get_glyph_dsc_cb(const lv_font_t * font, lv_font_glyph_dsc_t * d
     };
 
     int adv_w;
-    lv_cache_entry_t * entry = lv_cache_acquire_or_create(dsc->glyph_cache, &search_key, (void *)dsc);
+    /* A failed create callback can mean either an allocation failure or simply
+     * that the TTF has no glyph for this code point. Check an existing cache
+     * entry first, then distinguish a normal missing glyph before asking the
+     * cache to create a new entry. This also lets lv_font.c try the fallback
+     * font without emitting the misleading "cache not allocated" error. */
+    lv_cache_entry_t * entry = lv_cache_acquire(dsc->glyph_cache, &search_key, (void *)dsc);
+    if(entry == NULL && stbtt_FindGlyphIndex(&dsc->info, (int)unicode_letter) == 0) {
+        return false;
+    }
+    if(entry == NULL) {
+        entry = lv_cache_acquire_or_create(dsc->glyph_cache, &search_key, (void *)dsc);
+    }
 
     if(entry == NULL) {
         if(!dsc->cache_size) {  /* no cache, do everything directly */
@@ -249,7 +260,7 @@ static bool ttf_get_glyph_dsc_cb(const lv_font_t * font, lv_font_glyph_dsc_t * d
             dsc_out->entry = NULL;
             return true;
         }
-        LV_LOG_ERROR("cache not allocated");
+        LV_LOG_ERROR("glyph cache entry allocation failed");
         return false;
     }
 
@@ -309,7 +320,7 @@ static const void * ttf_get_glyph_bitmap_cb(lv_font_glyph_dsc_t * g_dsc, lv_draw
                 return NULL;
             }
         }
-        LV_LOG_ERROR("cache not allocated");
+        LV_LOG_ERROR("glyph bitmap cache entry allocation failed");
         return NULL;
     }
 
