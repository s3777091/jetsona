# --- Secrets / env ---
.env
.env.local
.env.*.local
*.key
*.pem

# --- Build artifacts (CMake) ---
build/
cmake-build-*/
out/
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.exe

# Firmware binary
jetson_fw
/jetson_fw

# --- CMake generated files ---
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json
*.cmake
!CMakeLists.txt
!**/CMakeLists.txt

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# --- Runtime / logs ---
*.log
jetson-fw.log
~/.jetson-fw/

# --- Python (build-time asset fetcher only) ---
__pycache__/
*.pyc

# --- Packaging ---
*.tar.gz
jetson.tar.gz

# --- Runtime assets (data) ---
# Assets are NOT in git. They are fetched from MinIO (S3) at build time by
# scripts/fetch_assets.sh -> scripts/s3_assets.py (idempotent: skips files
# already present). See .env.example for MINIO_* config. Never commit
# binaries / large data into the repo.
/assets/
/assets/**