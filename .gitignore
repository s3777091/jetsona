# --- Python (build-time asset fetcher only) ---
__pycache__/
*.pyc

# --- Packaging ---
*.tar.gz
jetson.tar.gz

# --- Runtime assets (data) ---
# Assets are fetched from MinIO (S3) at build time by scripts/fetch_assets.sh
# -> scripts/s3_assets.py. Keep the small Studio launcher icon in Git because
# the UI references it unconditionally and must also work with an old/offline
# asset cache. Continue ignoring every other runtime asset.
/assets/*
!/assets/icons/
/assets/icons/*
!/assets/icons/drawer/
/assets/icons/drawer/*
!/assets/icons/drawer/studio.png
