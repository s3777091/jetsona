# --- Secrets / env ---
.env
.env.local
.env.*.local
*.key
*.pem

# --- Build artifacts (CMake) ---
# Glob, not just `build/`: JETSON_BUILD_DIR lets the backend pick its own tree
# (build-fbdev, build-drm, ...). A bare `build/` once let build-fbdev/ be
# committed, dragging 13 MB of copied runtime assets into Git even though
# /assets/* is ignored -- the copies bypassed that rule entirely.
build*/
cmake-build-*/
out/
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.exe

# Firmware binary
jetson_fw
/jetson_fw

# --- CMake generated files ---
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json
*.cmake
!CMakeLists.txt
!**/CMakeLists.txt

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# --- Runtime / logs ---
*.log
jetson-fw.log
~/.jetson-fw/

# --- Python (build-time asset fetcher only) ---
__pycache__/
*.pyc

# --- Packaging ---
*.tar.gz
jetson.tar.gz

# --- Screenshots / scratch captures ---
# Debug captures belong in S3 (or nowhere), never in the repo.
.agents/
*.screenshot.png

# --- Runtime assets (data) ---
# Assets are fetched from MinIO (S3) at build time by scripts/fetch_assets.sh
# -> scripts/s3_assets.py. Only the bundled monospace font is tracked in Git so
# the build still works with an old/offline asset cache. Every icon and the
# rest of the runtime data come from S3.
/assets/*
!/assets/fonts/
/assets/fonts/*
!/assets/fonts/SourceCodePro-Regular.ttf
!/assets/fonts/SourceCodePro-LICENSE.md
