[Unit]
Description=Jetson Nano AI Firmware (DS-02 UI)
After=network-online.target
Wants=network-online.target
# The firmware and Xorg both own the physical scanout. On a graphical boot,
# let display-manager win; on a multi-user kiosk boot, only the firmware runs.
Conflicts=display-manager.service
Before=display-manager.service

[Service]
Type=simple
WorkingDirectory=/opt/jetson-fw
ExecStart=/opt/jetson-fw/scripts/jetson_fw_run.sh
Restart=on-failure
RestartSec=3
# DRM/KMS needs root or the 'video'/'render' groups.
User=root
# Chiaki stores Remote Play registration keys below its private runtime home.
# Prevent any files created by the firmware/launchers from becoming group/world
# readable even when a helper forgets to pass an explicit chmod mode.
UMask=0077
Environment=JETSON_FW_LOG=/var/log/jetson-fw.log
StandardOutput=append:/var/log/jetson-fw.log
StandardError=append:/var/log/jetson-fw.log

[Install]
WantedBy=multi-user.target
