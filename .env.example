# Copy this file to .env and fill in only the credentials you use.
# Non-sensitive URLs, models, paths, hardware choices, and other setup belong
# in config.yaml. Both files are loaded by run.sh, build scripts, and systemd.

# Ollama Cloud (https://ollama.com/settings/keys)
OLLAMA_API_KEY=replace-with-your-ollama-cloud-key

# Exa web search (https://dashboard.exa.ai/api-keys)
EXA_API_KEY=replace-with-your-exa-key

# RunPod Pods/Studio (https://console.runpod.io/user/settings)
RUNPOD_API_KEY=

# Zing MP3 compatibility credentials. Upstream can rotate/reject the defaults
# mirrored by the client; set current values here without rebuilding. When
# anonymous calls are rejected, copy one complete browser Cookie header that
# includes a current zpsid. Never commit the real value.
ZING_API_KEY=
ZING_SECRET_KEY=
ZING_COOKIES=

# MinIO / S3 asset credentials
MINIO_ACCESS_KEY=replace-with-your-minio-access-key
MINIO_SECRET_KEY=replace-with-your-minio-secret-key
