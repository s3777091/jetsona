# Copy to .env and fill in. .env is gitignored.
# run.sh sources .env and exports these into the firmware process.
# scripts/fetch_assets.sh (build-time) also sources .env for the MinIO config
# below, so the firmware build auto-downloads assets from MinIO when missing.

# LLM: Ollama Cloud (OpenAI-compatible). Get a key at https://ollama.com/settings/keys
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=replace-with-your-ollama-cloud-key
# Tool-calling-capable models on Ollama Cloud: gemma4:31b, gpt-oss:20b, gpt-oss:120b, gemma3:27b, ...
OLLAMA_MODEL=gemma4:31b

# RunPod GPU cloud (drawer app "Pods" + "Studio"). Create an API key with
# pods read/write permission at https://console.runpod.io/user/settings
# -> API Keys. The Pods app rents/starts/stops GPU pods via
# https://rest.runpod.io/v1; Studio opens the running pod's web IDE
# (code-server/Jupyter, https://{podId}-{port}.proxy.runpod.net) in the
# Chromium kiosk. Leave empty to disable (the tiles will say so).
RUNPOD_API_KEY=

# The Studio tile's target: self-hosted code-server (VS Code web) on the VM,
# deployed by vm/code-server/deploy.py (prints this URL + login password).
# This is the default, free coding environment; GPU pods are rented and
# opened explicitly from the Pods app. Prefer the VM's Tailscale 100.x
# address over the public IP if the VM is in your tailnet (code-server is
# plain HTTP + password).
JETSON_STUDIO_URL=

# Web tools via the HTTP gateway on the VM (vm/lightpanda-search-gw,
# deployed by its deploy.py — it prints these two values).
# - web_search: GET {URL}?q=<query>  -> {"results":[{title,url,snippet},...]}
# - web_open:   GET {URL with /search -> /fetch}?url=<page> -> {title,text}
#   (page text rendered by the lightpanda container over CDP, fallback fetch;
#    set LIGHTPANDA_FETCH_URL only to override the derived /fetch endpoint)
# Both use Authorization: Bearer {TOKEN}. Leave empty to disable web tools.
LIGHTPANDA_SEARCH_URL=
LIGHTPANDA_SEARCH_TOKEN=

# Runtime assets on MinIO (S3-compatible). The build fetches assets/ from here
# if missing (scripts/s3_assets.py, idempotent -- skips files already present).
# Console: https://console.phuongdong.cloud/  S3 API: https://s3.phuongdong.cloud/
MINIO_ENDPOINT=https://s3.phuongdong.cloud
MINIO_ACCESS_KEY=replace-with-your-minio-access-key
MINIO_SECRET_KEY=replace-with-your-minio-secret-key
MINIO_BUCKET=jetsona-assets
MINIO_REGION=us-east-1
# Optional: only fetch objects under this prefix (default = whole bucket).
ASSETS_S3_PREFIX=
# Optional cloud-font manifest. Each TSV row is:
# Display name<TAB>regular.ttf<TAB>bold.ttf
# The files live under assets/fonts/cloud in the bucket and are downloaded only
# when selected in Cài đặt chung > Phông chữ > Phông chữ khác.
JETSON_FONT_CATALOG_OBJECT=fonts/cloud/catalog.tsv
# Optional override when the helper script is installed elsewhere.
JETSON_S3_ASSET_HELPER=
# 1 = tải sẵn toàn bộ font cloud khi build; mặc định 0 = tải khi người dùng chọn.
ASSETS_FETCH_CLOUD_FONTS=1

# Standby-screen weather line, from open-meteo.com (free, no API key).
# Defaults: TP.HCM. Find coordinates at https://open-meteo.com/en/docs
JETSON_WEATHER_LAT=10.7769
JETSON_WEATHER_LON=106.7009
JETSON_WEATHER_NAME=TP.HCM

# VPN (Tailscale exit node). This is the VM's Tailscale machine name or 100.x
# address, not its public SSH address. scripts/setup-tailscale-exit-node.sh
# configures the VM with this default name.
JETSON_VPN_EXIT_NODE=jetsona-vpn

# PS5 Remote Play (Chiaki). CHIAKI_BIN may be chiaki-ng, chiaki, or an ARM64
# AppImage path. Empty means auto-detect installed binaries and AppImages.
CHIAKI_BIN=
PS_REMOTE_PLAY_HOME=/var/lib/jetson-fw/chiaki
PS_REMOTE_PLAY_STATE_FILE=/var/lib/jetson-fw/ps-remote-play.conf
PS_REMOTE_PLAY_AUDIO_DRIVER=alsa
# software is the reliable Jetson Nano default. Optional: auto, vulkan, vaapi,
# or cuda when using a custom Chiaki build that actually provides that decoder.
PS_REMOTE_PLAY_HW_DECODER=software
# Vulkan is preferred; opengl is the compatibility fallback.
PS_REMOTE_PLAY_RENDER_BACKEND=vulkan
# Maximize clocks only while streaming; the launcher stores/restores them.
PS_REMOTE_PLAY_MAX_CLOCKS=1
# auto uses FUSE when available and AppImage extraction otherwise.
PS_REMOTE_PLAY_APPIMAGE_EXTRACT=auto
PS_REMOTE_PLAY_PROBE_TIMEOUT=5
PS_REMOTE_PLAY_WAKE_TIMEOUT=25
