# Copy to .env and fill in. .env is gitignored.
# run.sh sources .env and exports these into the firmware process.

# LLM: Ollama Cloud (OpenAI-compatible). Get a key at https://ollama.com/settings/keys
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=replace-with-your-ollama-cloud-key
# Tool-calling-capable models on Ollama Cloud: gemma4:31b, gpt-oss:20b, gpt-oss:120b, gemma3:27b, ...
OLLAMA_MODEL=gemma4:31b

# Web search via a Lightpanda-backed HTTP gateway on the VM.
# Gateway contract: GET {URL}?q=<query> with Authorization: Bearer {TOKEN}
# -> {"results":[{"title","url","snippet"}, ...]}
# Leave empty to disable web search (task/note tools still work).
LIGHTPANDA_SEARCH_URL=
LIGHTPANDA_SEARCH_TOKEN=