# Local runtime config for jetson_fw. GITIGNORED — do not commit real secrets.
# run.sh sources this and exports the vars into the firmware process.

# ---- LLM: Ollama Cloud (OpenAI-compatible) ----
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=5c000d0db48e44cf98d053753f527f8b.ZLPZ5-SH_9E7grx7u-g7-92S
# Models on this cloud account: gemma4:31b, gpt-oss:20b, gpt-oss:120b,
# gemma3:12b/27b, glm-5, kimi-k2.6, deepseek-v3.2, mistral-large-3:675b, ...
# gemma4:31b supports tool-calling (verified) and is the chosen default.
OLLAMA_MODEL=gemma4:31b

# ---- Web search via the search gateway (on the VM) ----
# Gateway: GET {URL}?q=<query> with Authorization: Bearer {TOKEN}
#   -> {"results":[{"title","url","snippet"}, ...]}
# Deployed 2026-07-13 at http://36.50.27.142:9233 (Bing-backed, cheerio parse).
# LightPanda was the original plan but its renderer drops DDG's results <table>
# and DDG started blocking the VM IP; Bing HTML works reliably. The lightpanda
# container is left untouched for future JS-heavy scraping.
LIGHTPANDA_SEARCH_URL=http://36.50.27.142:9233/search
LIGHTPANDA_SEARCH_TOKEN=lp_ebb5779078d91027a475609d28f918b1cdecffe5

# ---- Optional overrides ----
# HOME is used to locate ~/.jetson-fw/{settings.kv,tasks.json}. Usually set.